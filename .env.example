# OpenRouter (single API for all models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# PostHog
POSTHOG_API_KEY=your_posthog_project_api_key_here
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_APP_HOST=https://us.posthog.com
POSTHOG_PERSONAL_API_KEY=your_personal_api_key_here

# App
APP_HOST=0.0.0.0
APP_PORT=8000
# Public base URL the app is served from — used to stamp `game_url` on
# LLM events so PostHog traces can link back to the game page.
APP_BASE_URL=https://hot-hog-app-production.up.railway.app
DATABASE_URL=sqlite:///./hot_hog.db
